#!/usr/bin/env bash
#MISE description="Initialize git-crypt with default and optional named keys"
#USAGE arg "[key_names]..." help="Named keys to create (in addition to default)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

TARGET="$(rudi_target_dir)"
rudi_require_git_crypt
rudi_require_git "$TARGET"

# Always init the default key
git -C "$TARGET" crypt init
echo "Initialized default key"

# Init any named keys
for key_name in $usage_key_names; do
  git -C "$TARGET" crypt init --key-name "$key_name"
  echo "Initialized named key: $key_name"
done
