#!/usr/bin/env bash
#MISE description="Rotate a named key (re-encrypt files with a new key)"
#USAGE flag "-k --key <name>" help="Named key to rotate (default: default key)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

TARGET="$(rudi_target_dir)"
rudi_require_git_crypt
rudi_require_git "$TARGET"

KEY_NAME="${usage_key:-default}"

GPG_DIR="$TARGET/.git-crypt/keys/$KEY_NAME/0"

if [ ! -d "$GPG_DIR" ]; then
  echo "Error: key '$KEY_NAME' does not exist" >&2
  exit 1
fi

# Collect remaining collaborator fingerprints before we tear down the key
FPRS=()
for gpg_file in "$GPG_DIR"/*.gpg; do
  [ -f "$gpg_file" ] || continue
  fpr=$(basename "$gpg_file" .gpg)
  FPRS+=("$fpr")
done

if [ ${#FPRS[@]} -eq 0 ]; then
  echo "Error: no collaborators on key '$KEY_NAME'. Nothing to rotate." >&2
  echo "Add collaborators first with: rudi add-user <fpr> --key $KEY_NAME" >&2
  exit 1
fi

echo "Rotating key: $KEY_NAME"
echo "Collaborators to re-add: ${#FPRS[@]}"

# Collect patterns assigned to this key from .gitattributes
PATTERNS=()
if [ -f "$TARGET/.gitattributes" ]; then
  if [ "$KEY_NAME" = "default" ]; then
    # Default key: lines with filter=git-crypt but NOT filter=git-crypt-<name>
    while IFS= read -r line; do
      pattern=$(echo "$line" | awk '{print $1}')
      PATTERNS+=("$pattern")
    done < <(grep 'filter=git-crypt ' "$TARGET/.gitattributes" | grep -v 'filter=git-crypt-')
  else
    while IFS= read -r line; do
      pattern=$(echo "$line" | awk '{print $1}')
      PATTERNS+=("$pattern")
    done < <(grep "filter=git-crypt-${KEY_NAME} " "$TARGET/.gitattributes")
  fi
fi

echo "Patterns: ${PATTERNS[*]:-none}"

# Step 1: Find all files protected by this key and save their plaintext content
FILE_CACHE="$(mktemp -d)"
FILE_LIST=()
for pattern in "${PATTERNS[@]}"; do
  while IFS= read -r file; do
    [ -f "$TARGET/$file" ] || continue
    if rudi_is_plaintext "$TARGET/$file"; then
      # Encode path for safe filesystem storage (replace / with __)
      encoded="$(printf '%s' "$file" | sed 's|/|__|g')"
      cp "$TARGET/$file" "$FILE_CACHE/$encoded"
      FILE_LIST+=("$file")
    else
      echo "Warning: $file is currently encrypted (locked). Unlock first." >&2
      echo "Run: git-crypt unlock" >&2
      rm -rf "$FILE_CACHE"
      exit 1
    fi
  done < <(git -C "$TARGET" ls-files -- "$pattern" 2>/dev/null)
done

echo "Files to re-encrypt: ${#FILE_LIST[@]}"

# Step 2: Lock files under this key so we can safely remove the old key
if [ "$KEY_NAME" = "default" ]; then
  git -C "$TARGET" crypt lock 2>/dev/null || true
else
  git -C "$TARGET" crypt lock --key-name "$KEY_NAME" 2>/dev/null || true
fi

# Step 3: Remove the old key's .gpg files and local key material
git -C "$TARGET" rm -rf "$GPG_DIR" 2>/dev/null || true
rm -f "$TARGET/.git/git-crypt/keys/$KEY_NAME"

# Step 4: Re-initialize the key (generates fresh symmetric key)
if [ "$KEY_NAME" = "default" ]; then
  git -C "$TARGET" crypt init 2>/dev/null
else
  git -C "$TARGET" crypt init --key-name "$KEY_NAME" 2>/dev/null
fi

# Step 5: Re-add all remaining collaborators
for fpr in "${FPRS[@]}"; do
  cmd=(git -C "$TARGET" crypt add-gpg-user --trusted)
  if [ "$KEY_NAME" != "default" ]; then
    cmd+=(--key-name "$KEY_NAME")
  fi
  cmd+=("$fpr")
  "${cmd[@]}" 2>/dev/null
  echo "  Re-added: $fpr"
done

# Step 6: Unlock with the new key so files become plaintext again
git -C "$TARGET" crypt unlock 2>/dev/null || true

# Step 7: Restore file contents (they may have been re-encrypted with old key data in git objects)
# The files should already be plaintext after unlock, but let's ensure content is correct
for file in "${FILE_LIST[@]}"; do
  encoded="$(printf '%s' "$file" | sed 's|/|__|g')"
  cp "$FILE_CACHE/$encoded" "$TARGET/$file"
done
rm -rf "$FILE_CACHE"

# Step 8: Stage and commit the re-encrypted files
git -C "$TARGET" add .
git -C "$TARGET" commit -q -m "Rotate key '$KEY_NAME': re-encrypted with fresh key" 2>/dev/null || true

echo ""
echo "Key '$KEY_NAME' rotated successfully."
echo "  New symmetric key generated"
echo "  ${#FPRS[@]} collaborator(s) re-added"
echo "  ${#FILE_LIST[@]} file(s) re-encrypted"
