#!/usr/bin/env bash
#MISE description="Add a GPG user to a key"
#USAGE arg "<fingerprint>" help="GPG fingerprint of the user to add"
#USAGE flag "-k --key <name>" help="Named key to add user to (default: default key)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

TARGET="$(rudi_target_dir)"
rudi_require_git_crypt
rudi_require_git "$TARGET"

FPR="$usage_fingerprint"
KEY_NAME="${usage_key:-}"

# Check if this fingerprint is already a collaborator for this key
if [ -n "$KEY_NAME" ]; then
  GPG_FILE="$TARGET/.git-crypt/keys/$KEY_NAME/0/$FPR.gpg"
  LABEL="key: $KEY_NAME"
else
  GPG_FILE="$TARGET/.git-crypt/keys/default/0/$FPR.gpg"
  LABEL="default key"
fi

if [ -f "$GPG_FILE" ]; then
  echo "$FPR already added to $LABEL"
else
  cmd=(git -C "$TARGET" crypt add-gpg-user --trusted)
  [ -n "$KEY_NAME" ] && cmd+=(--key-name "$KEY_NAME")
  cmd+=("$FPR")

  "${cmd[@]}"

  echo "Added $FPR to $LABEL"
fi

# Regenerate COLLABORATORS manifest
CALLER_PWD="$TARGET" mise -C "$MISE_CONFIG_ROOT" run -q collaborators 2>/dev/null || true
