#!/usr/bin/env bash
#MISE description="Regenerate COLLABORATORS manifest for all keys"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

TARGET="$(rudi_target_dir)"
rudi_require_git_crypt
rudi_require_git "$TARGET"

KEYS_DIR="$TARGET/.git-crypt/keys"

if [ ! -d "$KEYS_DIR" ]; then
  echo "No keys found. Run: rudi add-user" >&2
  exit 1
fi

MANIFEST="$TARGET/.git-crypt/COLLABORATORS"

{
  echo "# Who can decrypt this repo"
  echo "# Auto-generated by rudi collaborators"
  echo "#"
  echo "# Each entry includes the collaborator's full GPG public key and which"
  echo "# keys they have access to. Fingerprints are derived from public keys —"
  echo "# verify with: rudi verify --fingerprint <fpr>"
  echo "#"
  echo "# Patterns per key (from .gitattributes):"
  if [ -f "$TARGET/.gitattributes" ]; then
    # Show default key patterns
    default_patterns=$(grep 'filter=git-crypt ' "$TARGET/.gitattributes" 2>/dev/null \
      | grep -v 'filter=git-crypt-' | awk '{print $1}' | tr '\n' ', ' | sed 's/,$//')
    [ -n "$default_patterns" ] && echo "#   default: $default_patterns"
    # Show named key patterns
    for key_dir in "$KEYS_DIR"/*/; do
      key_name=$(basename "$key_dir")
      [ "$key_name" = "default" ] && continue
      key_patterns=$(grep "filter=git-crypt-${key_name} " "$TARGET/.gitattributes" 2>/dev/null \
        | awk '{print $1}' | tr '\n' ', ' | sed 's/,$//')
      [ -n "$key_patterns" ] && echo "#   $key_name: $key_patterns"
    done
  fi
  echo ""

  # Collect all unique fingerprints across all keys (parallel arrays for bash 3.2 compat)
  fpr_list=()
  fpr_key_list=()
  for key_dir in "$KEYS_DIR"/*/; do
    key_name=$(basename "$key_dir")
    gpg_dir="$key_dir/0"
    [ -d "$gpg_dir" ] || continue
    for gpg_file in "$gpg_dir"/*.gpg; do
      [ -f "$gpg_file" ] || continue
      fpr=$(basename "$gpg_file" .gpg)
      # Check if fpr already in list
      found=false
      if [ "${#fpr_list[@]}" -gt 0 ]; then
        for i in $(seq 0 $(( ${#fpr_list[@]} - 1 ))); do
          if [ "${fpr_list[$i]}" = "$fpr" ]; then
            fpr_key_list[$i]="${fpr_key_list[$i]}, $key_name"
            found=true
            break
          fi
        done
      fi
      if ! $found; then
        fpr_list+=("$fpr")
        fpr_key_list+=("$key_name")
      fi
    done
  done

  first=true
  for i in $(seq 0 $(( ${#fpr_list[@]} - 1 ))); do
    fpr="${fpr_list[$i]}"
    keys="${fpr_key_list[$i]}"
    uid=$(gpg --list-keys --with-colons "$fpr" 2>/dev/null \
      | awk -F: '/^uid/{print $10; exit}')

    if $first; then
      first=false
    else
      echo ""
    fi

    echo "## ${uid:-unknown}"
    echo "## Fingerprint: $fpr"
    echo "## Keys: $keys"
    gpg --armor --export "$fpr" 2>/dev/null
  done
} > "$MANIFEST"

# Stage the manifest
git -C "$TARGET" add "$MANIFEST"
if ! git -C "$TARGET" diff --cached --quiet -- "$MANIFEST"; then
  git -C "$TARGET" commit -q -m "Update COLLABORATORS manifest"
fi

# Count collaborators
total=${#fpr_list[@]}
echo "COLLABORATORS manifest updated: $total collaborator(s)"
echo "  File: $MANIFEST"
