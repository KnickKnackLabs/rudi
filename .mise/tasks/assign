#!/usr/bin/env bash
#MISE description="Assign a file pattern to an encryption key"
#USAGE arg "<pattern>" help="Glob pattern to encrypt (e.g. 'notes/**', 'HUMAN.md')"
#USAGE flag "-k --key <name>" help="Named key to assign pattern to (default: default key)"
set -eo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

TARGET="$(rudi_target_dir)"
rudi_require_git "$TARGET"

PATTERN="$usage_pattern"
KEY_NAME="${usage_key:-}"
GITATTR="$TARGET/.gitattributes"

# Build the filter/diff attribute string
if [ -z "$KEY_NAME" ] || [ "$KEY_NAME" = "default" ]; then
  ATTR="filter=git-crypt diff=git-crypt"
  LABEL="default key"
else
  ATTR="filter=git-crypt-${KEY_NAME} diff=git-crypt-${KEY_NAME}"
  LABEL="key: $KEY_NAME"
fi

# Check if this pattern is already assigned
if [ -f "$GITATTR" ] && grep -F "$PATTERN" "$GITATTR" | grep -qF "$ATTR"; then
  echo "Pattern '$PATTERN' already assigned to $LABEL"
else
  printf '%-40s %s\n' "$PATTERN" "$ATTR" >> "$GITATTR"
  echo "Assigned '$PATTERN' to $LABEL"
fi

# Stage .gitattributes so clones pick up the encryption config
git -C "$TARGET" add "$GITATTR"
